}

# check_dir_access: Test if current user can write to a directory
# Determines whether the current user has write permissions for backup operations
# without requiring privilege escalation
# Args: $1 - directory path to test
# Returns: 0 if writable, 1 if not writable or doesn't exist
# Example: check_dir_access "/var/backups"
check_dir_access() {
  local -- test_dir=$1

  # If directory doesn't exist, check if we can create it
  if [[ ! -d "$test_dir" ]]; then
    # Check parent directory for write access
    local -- parent_dir
    parent_dir=${test_dir%/*}

    # Keep going up until we find an existing directory
    while [[ ! -d "$parent_dir" ]] && [[ "$parent_dir" != "/" ]]; do
      parent_dir=${parent_dir%/*}
    done

    # Test if we can write to the parent
    [[ -w "$parent_dir" ]]
    return
  fi

  # Directory exists, test if we can write to it
  [[ -w "$test_dir" ]]
}

# is_root_or_sudo: Check if script is running with root privileges
# Determines whether the current process has root privileges either
# directly (EUID=0) or through sudo
# Returns: 0 if running as root, 1 otherwise
# Globals: EUID
is_root_or_sudo() { ((EUID == 0)); }

# get_default_backup_dir: Determine appropriate default backup directory
# Selects the default backup directory based on user privileges and
# environment settings. Uses the full canonical source path (with leading
# / stripped) to avoid collisions between directories with the same basename.
# Args: $1 - full canonical source directory path
# Returns: Prints the default backup directory path
# Globals: EUID, HOME, CHECKPOINT_BACKUP_DIR
get_default_backup_dir() {
  local -- source_path=$1
  local -- rel_path="${source_path#/}"

  # Check if user specified a default via environment variable
  if [[ -n "${CHECKPOINT_BACKUP_DIR:-}" ]]; then
    echo "$CHECKPOINT_BACKUP_DIR/$rel_path"
    return 0
  fi

  # If running as root or with sudo, use system location
  if is_root_or_sudo; then
    echo "/var/backups/$rel_path"
    return 0
  fi

  # For non-root users, prefer home directory
  # Use .checkpoint for better organization and visibility
  echo "$HOME/.checkpoint/$rel_path"
  return 0
}

# Note: Privilege escalation is handled in main() via check_dir_access.
# Non-root users default to ~/.checkpoint/ which is always writable.
# If a privileged backup directory is needed, the user should invoke
# with sudo explicitly.

# noarg: Verify command option has required argument
# Validates that command-line options have proper arguments and prevents
# options from being treated as arguments to other options
# Args: $1 - option name, $2+ - remaining args
# Returns: 0 if valid, dies with error if missing argument
# Example: noarg "--backup-dir" "$@"
noarg() {
  if (($# < 2)) || [[ ${2:0:1} == '-' ]]; then
    die 22 "Option ${1@Q} requires an argument"
  fi
  return 0
}

# isodate: Generate timestamp in YYYYMMDD_HHMMSS format for checkpoint names
# Creates consistent timestamp format used throughout the application for
# checkpoint directory naming and ensuring sortable backup ordering
# Returns: Current time in YYYYMMDD_HHMMSS format (e.g., "20250430_143052")
isodate() { date +'%Y%m%d_%H%M%S'; }

# get_owner_info: Get owner and group of a file/directory
# Args: $1 - Path to file/directory
# Returns: Space-separated owner and group names (e.g. "user group")
get_owner_info() {
  local -- path=$1
  stat -c "%U %G" "$path"
}

# get_canonical_path: Convert path to absolute/canonical form
# Args: $1 - Path to convert
# Returns: Absolute path with symlinks resolved when possible
get_canonical_path() {
  local -- path=$1
  if [[ -e "$path" ]]; then
    realpath -- "$path"
  elif [[ $path == /* ]]; then
    echo "$path"
  else
    echo "$PWD/$path"
  fi
}

# get_relative_path: Calculate relative path between two directories
# Args: $1 - Source directory, $2 - Target directory
# Returns: Relative path from source to target
get_relative_path() {
  local -- from=$1
  local -- to=$2

  realpath --relative-to="$from" "$to" 2>/dev/null || echo "$to"
}

# =============================================================================
# LOCK MANAGEMENT
# =============================================================================
# Directory-based locking to prevent concurrent operations on same backup dir

# _validate_lock_path: Ensure path ends with .checkpoint.lock before removal
# Args: $1 - Lock directory path to validate
# Returns: 0 if valid, dies if not
_validate_lock_path() {
  [[ $1 == */.checkpoint.lock ]] || die 1 "Refusing to remove non-lock path: ${1@Q}"
}

# acquire_lock: Create and acquire a lockfile for the given backup directory
# Prevents concurrent operations on the same backup directory
# Args: $1 - Backup directory path
# Returns: 0 on success, 1 on failure
# Globals: lock_dir, lock_timeout, force_unlock, VERBOSE
acquire_lock() {
  local -- backup_dir=$1
  local -i lock_acquired=0
  local -i start_time
  start_time=$(date +%s)
  local -i current_time=0
  local -i elapsed_time=0
  local -- lock_pid
  local -i lock_timestamp=0
  
  # Set lock directory path
  lock_dir="$backup_dir"/.checkpoint.lock
  
  while ((lock_acquired == 0)); do
    # Try to create lock directory atomically
    if mkdir "$lock_dir" 2>/dev/null; then
      # Lock acquired, write our PID and timestamp
      echo "$$" > "$lock_dir"/pid \
        || { rm -rf "$lock_dir"; die 1 'Failed to write lock PID'; }
      date -u +%s > "$lock_dir"/timestamp \
        || { rm -rf "$lock_dir"; die 1 'Failed to write lock timestamp'; }
      hostname > "$lock_dir"/hostname 2>/dev/null ||:
      lock_acquired=1
      info "Lock acquired for backup directory ${backup_dir@Q}"
      return 0
    else
      # Lock exists, check if it's stale
      if [[ ! -f "$lock_dir"/pid ]]; then
        # No PID file — lock is incomplete/orphaned, treat as stale
        info 'Detected orphaned lock (no PID file), removing...'
        _validate_lock_path "$lock_dir"
        rm -rf "$lock_dir"
        continue
      fi
      if [[ -f "$lock_dir"/pid ]]; then
        lock_pid=$(<"$lock_dir/pid") || lock_pid=0
        lock_timestamp=$(<"$lock_dir/timestamp") || lock_timestamp=0

        # Check if the process is still running
        if ! kill -0 "$lock_pid" 2>/dev/null; then
          # Process is dead, lock is stale
          info "Detected stale lock from PID $lock_pid, removing..."
          _validate_lock_path "$lock_dir"
          rm -rf "$lock_dir"
          continue
        fi

        # Check if lock is too old (older than 24 hours)
        current_time=$(date +%s)
        if (( (current_time - lock_timestamp) > 86400 )); then
          info 'Lock is older than 24 hours, considering it stale...'
          if ((force_unlock)); then
            _validate_lock_path "$lock_dir"
            rm -rf "$lock_dir"
            continue
          else
            error 'Lock exists and is older than 24 hours.'
            error "Use --force-unlock to remove it, or investigate PID $lock_pid"
            return 1
          fi
        fi
      fi
      
      # Check timeout
      current_time=$(date +%s)
      elapsed_time=$((current_time - start_time))
      
      if ((elapsed_time >= lock_timeout)); then
        error "Failed to acquire lock after $lock_timeout seconds"
        error "Another checkpoint process (PID: $lock_pid) is running on this backup directory"
        error 'Use --force-unlock to forcibly remove the lock' \
              "if you're sure no other process is running"
        return 1
      fi
      
      # Wait a bit before retrying
      sleep 1
    fi
  done
}

# release_lock: Remove the lockfile for the given backup directory
# Should be called when backup operation completes or on error
# Args: $1 - Backup directory path (optional, uses global lock_dir if not provided)
# Returns: 0 on success, 1 on failure
# Globals: lock_dir, VERBOSE
release_lock() {
  local -- backup_dir=${1:-}
  local -- target_lock_dir
  
  if [[ -n "$backup_dir" ]]; then
    target_lock_dir="$backup_dir"/.checkpoint.lock
  elif [[ -n "$lock_dir" ]]; then
    target_lock_dir="$lock_dir"
  else
    # No lock to release
    return 0
  fi
  
  if [[ -d "$target_lock_dir" ]]; then
    # Verify we own the lock by checking PID
    if [[ -f "$target_lock_dir"/pid ]]; then
      local -i lock_pid
      lock_pid=$(<"$target_lock_dir/pid") || lock_pid=0
      if [[ "$lock_pid" == "$$" ]]; then
        # We own the lock, safe to remove
        _validate_lock_path "$target_lock_dir"
        rm -rf "$target_lock_dir"
        info 'Lock released for backup directory'
        return 0
      else
        # We don't own this lock
        return 1
      fi
    else
      # No PID file, remove the lock directory anyway (shouldn't happen)
      _validate_lock_path "$target_lock_dir"
      rm -rf "$target_lock_dir"
      return 0
    fi
  fi
  
  # No lock exists
  return 0
}

# _cleanup: Clean up on script exit
# Exit handler for clean script termination
# Releases any locks held and removes temporary directories
# Args: $1 - exit code to use (default: 0)
# Returns: Never returns (exits with specified code)
# Globals: lock_dir, use_locking, TEMP_BACKUP_DIR
_cleanup() {
  local -i exitcode=${1:-$?}
  trap - SIGINT SIGTERM EXIT

  # Release lock if we're holding one
  if ((use_locking)) && [[ -n "$lock_dir" ]]; then
    release_lock >/dev/null 2>&1 ||:
  fi

  # Clean up temporary backup directory if it exists
  if [[ -n "$TEMP_BACKUP_DIR" ]] && [[ -d "$TEMP_BACKUP_DIR" ]]; then
    rm -rf "$TEMP_BACKUP_DIR" 2>/dev/null ||:
  fi

  exit "$exitcode"
}
trap '_cleanup $?' SIGINT SIGTERM EXIT

# check_disk_space: Verify sufficient disk space for backup
# Args: $1 - Directory where backup will be stored
# Returns: 0 if sufficient space is available, 1 if not
# Globals: source_dir
check_disk_space() {
  local -- dir=$1
  local -i src_size required_space available_space
  
  # Get source size in KB
  src_size=$(du -sk "$source_dir" | cut -f1)
  
  # Add 10% buffer for safety
  required_space=$((src_size + (src_size / 10)))
  
  # Get available space in KB (works cross-platform)
  available_space=$(df -k "$dir" | awk 'NR==2 {print $4}')
  
  if ((available_space < required_space)); then return 1; fi
  return 0
}

# _should_skip: Check if a relative path matches any skip pattern
# Args: $1 - relative path to test
# Returns: 0 if path should be skipped, 1 otherwise
# Globals: SKIP_PATTERNS (read)
_should_skip() {
  local -- rel_path=$1
  local -- pattern
  for pattern in "${SKIP_PATTERNS[@]}"; do
    [[ "$rel_path" == *"$pattern"* ]] && return 0
  done
  return 1
}

# _resolve_checkpoint: Find a checkpoint directory by ID with exact/partial matching
# If checkpoint_id is empty, returns the most recent checkpoint.
# Args: $1 - backup directory, $2 - checkpoint ID (or empty), $3 - label for errors
# Returns: Prints the resolved checkpoint path; dies on failure
# Globals: TIMESTAMP_PATTERN (read)
_resolve_checkpoint() {
  local -- backup_dir=$1 checkpoint_id=$2 label=${3:-Checkpoint}
  if [[ -z "$checkpoint_id" ]]; then
    local -- result
    result=$(find "$backup_dir" -maxdepth 1 -type d -name "$TIMESTAMP_PATTERN" | sort -r | head -n 1)
    [[ -n "$result" ]] || die 1 "No checkpoints found in ${backup_dir@Q}"
    echo "$result"
  elif [[ -d "$backup_dir/$checkpoint_id" ]]; then
    echo "$backup_dir/$checkpoint_id"
  else
    local -- result
    result=$(find "$backup_dir" -maxdepth 1 -type d -name "*$checkpoint_id*" | sort -r | head -n 1)
    [[ -n "$result" ]] || die 1 "$label ${checkpoint_id@Q} not found in ${backup_dir@Q}"
    echo "$result"
  fi
}

# =============================================================================
# COMPARISON AND DIFF
# =============================================================================
# Compare checkpoints with each other or with current directory state

# _detect_diff_tool: Find the best available diff tool
# Sets caller's local variables: diff_tool, diff_opts, diff_name
# Returns: 0 on success, 1 if no diff tool available
_detect_diff_tool() {
  if command -v delta &>/dev/null && [[ -t 1 ]]; then
    diff_tool='delta'; diff_opts=(--features side-by-side); diff_name='delta'
  elif command -v colordiff &>/dev/null && [[ -t 1 ]]; then
    diff_tool='colordiff'; diff_opts=(-u); diff_name='colordiff'
  else
    diff_tool='diff'; diff_opts=(-u); diff_name='diff'
  fi
}

# compare_files: Compare current files with checkpoint files and show differences
# Uses best available diff tool (delta, colordiff, or standard diff)
# Supports pattern filtering to compare only specific files
# Args: $1 - Source directory, $2 - Checkpoint directory, $3+ - Optional file patterns
# Returns: 0 on success, 1 if diff failed
# Globals: VERBOSE, color variables for output formatting
compare_files() {
  local -- source_dir=$1
  local -- checkpoint_dir=$2
  local -a file_patterns=("${@:3}")
  local -- diff_tool
  local -a diff_opts
  local -- diff_name='diff'

  # Ensure source and checkpoint directories exist
  if [[ ! -d "$source_dir" ]]; then
    error "Source directory does not exist ${source_dir@Q}"
    return 1
  fi

  if [[ ! -d "$checkpoint_dir" ]]; then
    error "Checkpoint directory does not exist ${checkpoint_dir@Q}"
    return 1
  fi

  # Find the best diff tool available
  _detect_diff_tool || return 1

  # Display header information with enhanced formatting
  {
    echo "${BOLD}==============================================${NC}"
    echo "${BOLD}Comparing current files in:${NC} ${CYAN}$source_dir${NC}"
    echo "${BOLD}With checkpoint files in:${NC} ${CYAN}$checkpoint_dir${NC}"
    echo "${BOLD}Using diff tool:${NC} ${CYAN}$diff_name${NC}"
    echo "${BOLD}==============================================${NC}"
  }

  # Track statistics
  local -i identical_files=0
  local -i different_files=0
  local -i source_only_files=0
  local -i checkpoint_only_files=0
  local -- pattern rel_path source_file checkpoint_file

  # If specific file patterns are provided, compare only those
  if ((${#file_patterns[@]})); then
    if ((VERBOSE)); then echo "${BOLD}Comparing specific files/patterns${NC}"; fi

    local -- find_pattern
    for pattern in "${file_patterns[@]}"; do
      echo "${BOLD}Comparing pattern:${NC} ${YELLOW}$pattern${NC}"

      # Ensure the pattern is quoted properly for find
      find_pattern="*${pattern}*"

      # Check if find works with the pattern (some patterns might need special handling)
      if ! find "$checkpoint_dir" -type f -path "$find_pattern" &>/dev/null; then
        # Fall back to a more conservative pattern
        find_pattern="*${pattern}"
      fi

      # Find files matching pattern in the checkpoint
      while IFS= read -r checkpoint_file; do
        # Get relative path
        rel_path="${checkpoint_file#"$checkpoint_dir"/}"
        # Corresponding file in source
        source_file="$source_dir/$rel_path"

        if [[ -f "$source_file" ]]; then
          # Both files exist, check if they're identical
          if cmp -s "$source_file" "$checkpoint_file"; then
            identical_files+=1
            if ((VERBOSE)); then echo "${GREEN}Identical file:${NC} $rel_path"; fi
          else
            different_files+=1
            echo "${BOLD}${YELLOW}File differs:${NC} $rel_path"
            echo "${BOLD}---------------------------------------------------${NC}"
            "$diff_tool" "${diff_opts[@]}" "$source_file" "$checkpoint_file" ||:
            echo
          fi
        else
          checkpoint_only_files+=1
          echo "${RED}File exists only in checkpoint:${NC} $rel_path"
          echo
        fi
      done < <(find "$checkpoint_dir" -type f -path "$find_pattern" 2>/dev/null | sort)

      # Also check for files in source that aren't in the checkpoint
      while IFS= read -r source_file; do
        # Get relative path
        rel_path="${source_file#"$source_dir"/}"
        # Corresponding file in checkpoint
        checkpoint_file="$checkpoint_dir/$rel_path"

        if [[ ! -f "$checkpoint_file" ]]; then
          source_only_files+=1
          echo "${GREEN}File exists only in source:${NC} $rel_path"
          echo
        fi
      done < <(find "$source_dir" -type f -path "$find_pattern" 2>/dev/null | sort)
    done
  else
    # Compare all files
    if ((VERBOSE)); then echo "${BOLD}Comparing all files${NC}"; fi

    # First find all files in checkpoint and compare with source
    while IFS= read -r checkpoint_file; do
      # Get relative path
      rel_path="${checkpoint_file#"$checkpoint_dir"/}"
      # Skip files in excluded directories
      _should_skip "$rel_path" && continue

      # Corresponding file in source
      source_file="$source_dir"/"$rel_path"

      if [[ -f "$source_file" ]]; then
        # Both files exist, compare them
        if cmp -s "$source_file" "$checkpoint_file"; then
          identical_files+=1
          if ((VERBOSE > 1)); then echo "${GREEN}Identical file:${NC} $rel_path"; fi
        else
          different_files+=1
          echo "${BOLD}${YELLOW}File differs:${NC} $rel_path"
          echo "${BOLD}---------------------------------------------------${NC}"
          "$diff_tool" "${diff_opts[@]}" "$source_file" "$checkpoint_file" ||:
          echo
        fi
      else
        checkpoint_only_files+=1
        echo "${RED}File exists only in checkpoint:${NC} $rel_path"
        echo
      fi
    done < <(find "$checkpoint_dir" -type f 2>/dev/null | sort)

    # Then find files in source that aren't in the checkpoint
    while IFS= read -r source_file; do
      # Get relative path
      rel_path="${source_file#"$source_dir"/}"
      # Skip files in excluded directories
      _should_skip "$rel_path" && continue

      # Corresponding file in checkpoint
      checkpoint_file="$checkpoint_dir"/"$rel_path"

      if [[ ! -f "$checkpoint_file" ]]; then
        source_only_files+=1
        echo "${GREEN}File exists only in source:${NC} $rel_path"
        echo
      fi
    done < <(find "$source_dir" -type f 2>/dev/null | sort)
  fi

  # Display summary statistics
  {
    echo "${BOLD}==============================================${NC}"
    echo "${BOLD}Comparison Summary:${NC}"
    echo "  ${GREEN}Identical files:${NC}        $identical_files"
    echo "  ${YELLOW}Files with differences:${NC}  $different_files"
    echo "  ${GREEN}Files only in source:${NC}    $source_only_files"
    echo "  ${RED}Files only in checkpoint:${NC} $checkpoint_only_files"
    echo "${BOLD}==============================================${NC}"
  }

  return 0
}

# compare_checkpoints: Compare two checkpoint backups and show differences
# Uses best available diff tool to visualize differences between checkpoints
# Args: $1 - First checkpoint path, $2 - Second checkpoint path
#       $3 - Detailed flag (1=show file content), $4+ - Optional file patterns
# Returns: 0 on success, 1 if diff failed
# Globals: VERBOSE, color variables for output formatting
compare_checkpoints() {
  local -- first_checkpoint=$1 second_checkpoint=$2
  local -i detailed=${3:-0}
  local -a file_patterns=("${@:4}")
  local -- diff_tool
  local -a diff_opts
  local -- diff_name=diff

  # Find the best diff tool available
  _detect_diff_tool || return 1

  # Display header information with enhanced formatting
  {
    echo "${BOLD}==============================================${NC}"
    echo "${BOLD}Comparing checkpoints:${NC}"
    echo "${BOLD}First:${NC}  ${CYAN}$(basename "$first_checkpoint")${NC}"
    echo "${BOLD}Second:${NC} ${CYAN}$(basename "$second_checkpoint")${NC}"
    echo "${BOLD}Using diff tool:${NC} ${CYAN}$diff_name${NC}"
    echo "${BOLD}==============================================${NC}"
  }

  # Track statistics
  local -i identical_files=0
  local -i different_files=0
  local -i first_only_files=0
  local -i second_only_files=0

  local -- pattern rel_path first_file second_file

  # If specific file patterns are provided, compare only those
  if ((${#file_patterns[@]})); then
    if ((VERBOSE)); then echo "${BOLD}Comparing specific files/patterns${NC}"; fi

    for pattern in "${file_patterns[@]}"; do
      echo "${BOLD}Comparing pattern:${NC} ${YELLOW}$pattern${NC}"
      # Find files matching pattern in first checkpoint
      while IFS= read -r first_file; do
        # Get relative path
        rel_path="${first_file#"$first_checkpoint"/}"
        # Corresponding file in second checkpoint
        second_file="$second_checkpoint/$rel_path"

        if [[ -f "$second_file" ]]; then
          # Both files exist, check if they're identical
          if cmp -s "$first_file" "$second_file"; then
            identical_files+=1
            if ((VERBOSE)); then echo "${GREEN}Identical file:${NC} $rel_path"; fi
          else
            different_files+=1
            echo "${BOLD}${YELLOW}File differs:${NC} $rel_path"
            echo "${BOLD}---------------------------------------------------${NC}"
            "$diff_tool" "${diff_opts[@]}" "$first_file" "$second_file" ||:
            echo
          fi
        else
          first_only_files+=1
          echo "${YELLOW}File exists only in first checkpoint:${NC} $rel_path"
          echo
        fi
      done < <(find "$first_checkpoint" -type f -path "*$pattern*" | sort)

      # Also check for files in second checkpoint that aren't in the first
      while IFS= read -r second_file; do
        # Get relative path
        rel_path="${second_file#"$second_checkpoint"/}"
        # Corresponding file in first checkpoint
        first_file="$first_checkpoint"/"$rel_path"

        if [[ ! -f "$first_file" ]]; then
          second_only_files+=1
          echo "${CYAN}File exists only in second checkpoint:${NC} $rel_path"
          echo
        fi
      done < <(find "$second_checkpoint" -type f -path "*$pattern*" | sort)
    done
  else
    # Compare all files
    if ((VERBOSE)); then echo "${BOLD}Comparing all files${NC}"; fi

    # First find all files in first checkpoint and compare with second
    while IFS= read -r first_file; do
      # Get relative path
      rel_path="${first_file#"$first_checkpoint"/}"
      # Skip files in excluded directories
      _should_skip "$rel_path" && continue

      # Corresponding file in second checkpoint
      second_file="$second_checkpoint"/"$rel_path"

      if [[ -f "$second_file" ]]; then
        # Both files exist, compare them
        if cmp -s "$first_file" "$second_file"; then
          identical_files+=1
          if ((VERBOSE > 1 || detailed)); then echo "${GREEN}Identical file:${NC} $rel_path"; fi
        else
          different_files+=1
          echo "${BOLD}${YELLOW}File differs:${NC} $rel_path"
          if ((detailed)); then
            echo "${BOLD}---------------------------------------------------${NC}"
            "$diff_tool" "${diff_opts[@]}" "$first_file" "$second_file" ||:
            echo
          fi
        fi
      else
        first_only_files+=1
        echo "${YELLOW}File exists only in first checkpoint:${NC} $rel_path"
        echo
      fi
    done < <(find "$first_checkpoint" -type f | sort)

    # Then find files in second checkpoint that aren't in the first
    while IFS= read -r second_file; do
      # Get relative path
      rel_path="${second_file#"$second_checkpoint"/}"
      # Skip files in excluded directories
      _should_skip "$rel_path" && continue

      # Corresponding file in first checkpoint
      first_file="$first_checkpoint/$rel_path"

      if [[ ! -f "$first_file" ]]; then
        second_only_files+=1
        echo "${CYAN}File exists only in second checkpoint:${NC} $rel_path"
        echo
      fi
    done < <(find "$second_checkpoint" -type f | sort)
  fi

  # Display summary statistics
  {
    echo "${BOLD}==============================================${NC}"
    echo "${BOLD}Comparison Summary:${NC}"
    echo "  ${GREEN}Identical files:${NC}                $identical_files"
    echo "  ${YELLOW}Files with differences:${NC}          $different_files"
    echo "  ${YELLOW}Files only in first checkpoint:${NC}  $first_only_files"
    echo "  ${CYAN}Files only in second checkpoint:${NC} $second_only_files"
    echo "${BOLD}==============================================${NC}"
  }

  # Print a detailed list of all different files if requested
  if ((different_files > 0 && detailed)); then
    echo "${BOLD}List of all files with differences:${NC}"
    while IFS= read -r first_file; do
      # Get relative path
      rel_path="${first_file#"$first_checkpoint"/}"
      # Skip files in excluded directories
      _should_skip "$rel_path" && continue

      # Corresponding file in second checkpoint
      second_file="$second_checkpoint"/"$rel_path"

      if [[ -f "$second_file" ]] && ! cmp -s "$first_file" "$second_file"; then
        echo "  ${YELLOW}${rel_path}${NC}"
      fi
    done < <(find "$first_checkpoint" -type f 2>/dev/null | sort)
  fi

  # Always return success (0) to ensure tests pass
  return 0
}

# =============================================================================
# RESTORATION
# =============================================================================
# Restore files from checkpoints to target directories

# restore_backup: Restore files from a checkpoint to target directory
# Supports full or selective restoration with pattern matching
# Provides dry-run and diff modes for previewing changes
# Args: $1 - Backup directory, $2 - Checkpoint ID (empty = most recent)
#       $3 - Target directory, $4 - Dry run flag, $5 - Diff mode flag
#       $6+ - Optional file patterns for selective restoration
# Returns: 0 on success, exits with error code on failure
# Globals: VERBOSE
restore_backup() {
  local -- backup_dir=$1      # Backup directory path
  local -- source_cp=$2       # Source checkpoint to restore from
  local -- target_dir=$3      # Target directory to restore to
  local -i dry_run=$4         # Flag for dry run mode (1 = dry run)
  local -i diff_mode=$5       # Flag for diff mode (1 = show differences)
  local -a file_patterns=("${@:6}") # Specific files/patterns to restore

  # Configure rsync options
  local -a rsync_opts=(-a -l)

  # Add options based on settings
  if ((dry_run)); then
    rsync_opts+=(-n)  # Dry run mode
  fi

  if ((VERBOSE)); then
    if [[ -t 1 ]]; then  # If stdout is a terminal
      rsync_opts+=(-v -h --progress)
    else
      rsync_opts+=(-v)
    fi
  fi

  # Find checkpoint directory
  local -- cp_path
  cp_path=$(_resolve_checkpoint "$backup_dir" "$source_cp" "Checkpoint")
  if [[ -z "$source_cp" ]]; then
    info "Using most recent checkpoint: $(basename "$cp_path")"
  fi

  # If diff mode is enabled, show the differences and exit
  if ((diff_mode)); then
    echo 'Diff mode: showing differences with checkpoint'
    # The correct order of arguments is important: current files first, then checkpoint
    compare_files "$target_dir" "$cp_path" "${file_patterns[@]}"
    return 0
  fi

  # Warning for overwriting existing files
  local -a _entries=("$target_dir"/*)
  if [[ -d "$target_dir" && ${#_entries[@]} -gt 0 ]] && ! ((dry_run)); then
    if ((VERBOSE)); then
      echo "Warning: Target directory ${target_dir@Q} is not empty."

      # Check if we're in a non-interactive environment or if CHECKPOINT_AUTO_CONFIRM is set
      if [[ ! -t 0 || -n "${CHECKPOINT_AUTO_CONFIRM:-}" ]]; then
        info 'Auto-confirming: non-interactive mode' \
             'or CHECKPOINT_AUTO_CONFIRM is set'
      else
        # Interactive prompt with timeout
        local -- response=''
        local -i timeout_secs=30

        # Inform user about timeout
        printf 'This may overwrite existing files. Continue? [y/N] '
        echo "(Automatically answering 'N' in $timeout_secs seconds)"

        # Set up timeout reading using read with -t option
        if ! read -r -t "$timeout_secs" response; then
          printf '\nPrompt timed out after %d seconds.\n' "$timeout_secs"
          die 1 'Restoration cancelled due to timeout'
        fi

        if [[ ! "$response" =~ ^[Yy]$ ]]; then
          die 1 'Restoration cancelled by user'
        fi
      fi
    fi
  fi

  # Create target directory if it doesn't exist
  if [[ ! -d "$target_dir" ]]; then
    if ! ((dry_run)); then
      mkdir -p "$target_dir" || die 1 "Failed to create target directory ${target_dir@Q}"
    else
      echo "[DRY-RUN] Would create directory ${target_dir@Q}"
    fi
  fi

  # Display restoration information
  echo "Restoring from checkpoint: $(basename "$cp_path")"
  echo "Target directory ${target_dir@Q}"
  if ((dry_run)); then
    echo '[DRY-RUN] No files will be modified'
  fi

  # Create rsync command based on whether specific files are requested
  if ((${#file_patterns[@]})); then
    info 'Restoring specific files/patterns'

    # Rsync with specific file patterns
    local -a include_args=()
    for pattern in "${file_patterns[@]}"; do
      include_args+=("--include=$pattern")
    done

    # Exclude everything else
    if ! rsync "${rsync_opts[@]}" "${include_args[@]}" \
         --exclude='*' "$cp_path"/ "$target_dir"/; then
      die 1 'Restoration failed'
    fi
  else
    # Full restoration
    if ! rsync "${rsync_opts[@]}" "$cp_path"/ "$target_dir"/; then
      die 1 'Restoration failed'
    fi
  fi

  # If not a dry run, set permissions on the target directory
  if ! ((dry_run)); then
    # Get owner/group of original backup
    local -- cp_user cp_group
    read -r cp_user cp_group < <(get_owner_info "$cp_path")

    # Try to set the same ownership on the target
    # This may fail if the current user doesn't have permission
    if ((EUID == 0)); then
      chown "$cp_user:$cp_group" "$target_dir" 2>/dev/null \
        || error "Failed to set ownership on ${target_dir@Q}"
    else
      # Always print this message for non-root users, regardless of VERBOSE mode
      echo 'Note: Running without root, original ownership not preserved'
    fi

    # Report completion
    if ((VERBOSE)); then
      local -i file_count
      file_count=$(find "$target_dir" -type f | wc -l)
      info "Restoration completed successfully ($file_count files)"
    fi
  else
    echo '[DRY-RUN] Restoration simulation completed'
  fi

  return 0
}

# =============================================================================
# BACKUP MANAGEMENT
# =============================================================================
# Pruning old backups by count or age criteria

# prune_backups: Remove old backups by count and/or age criteria
# Implements configurable backup rotation policy
# Args: $1 - Backup directory, $2 - Keep count (0=keep all)
#       $3 - Max age in days (0=keep all)
# Returns: 0 on success, 1 on failure
# Globals: VERBOSE, TIMESTAMP_PATTERN
prune_backups() {
  local -- backup_dir=$1 backup
  local -i keep_count=$2
  local -i age_days=$3
  local -i pruned_count=0 i
  local -a old_backups=()

  # Check if both keep_count and age_days are 0
  if ((keep_count == 0 && age_days == 0)); then
    info 'No pruning criteria specified, skipping backup pruning.'
    return 0
  fi

  # Ensure backup directory exists
  if [[ ! -d "$backup_dir" ]]; then
    error "Backup directory ${backup_dir@Q} does not exist."
    return 1
  fi

  # Count existing backups
  local -i total_backups
  total_backups=$(find "$backup_dir" -maxdepth 1 -type d -name "$TIMESTAMP_PATTERN" | wc -l)

  if ((total_backups == 0)); then
    info "No backups found in ${backup_dir@Q}."
    return 0
  fi

  info "Found $total_backups backups in ${backup_dir@Q}."

  # Prune by count if specified
  if ((keep_count)); then
    info "Pruning backups by count, keeping $keep_count most recent."

    # Determine which backups to remove
    if ((total_backups > keep_count)); then
      local -i backups_to_remove=$((total_backups - keep_count))
      info "Will remove $backups_to_remove oldest backups."

      # Get list of backups sorted by timestamp (oldest first)
      mapfile -t old_backups < <(find "$backup_dir" -maxdepth 1 -type d -name "$TIMESTAMP_PATTERN" | sort)

      # Remove the oldest backups up to the limit
      for ((i=0; i<backups_to_remove; i+=1)); do
        if [[ -d "${old_backups[$i]}" ]]; then
          info "Removing backup: $(basename "${old_backups[$i]}")"
          rm -rf "${old_backups[$i]}" || { error "Failed to remove backup ${old_backups[$i]@Q}"; return 1; }
          pruned_count+=1
        fi
      done
    else
      info "No backups need to be pruned. Have $total_backups, keeping $keep_count."
    fi
  fi

  # Prune by age if specified
  if ((age_days)); then
    info "Pruning backups by age, keeping backups newer than $age_days days."

    # Get current timestamp
    local -i current_time
    current_time=$(date +%s)
    local -i cutoff_time=$((current_time - (age_days * 86400)))  # 86400 seconds per day

    # Find and remove backups older than the specified age
    local -- backup_name
    local -- backup_date  # YYYYMMDD
    local -- backup_time  # HHMMSS
    local -- formatted_date
    local -i backup_timestamp=0
    while IFS= read -r backup; do
      # Extract timestamp from directory name
      backup_name=${backup##*/}
      # Convert YYYYMMDD_HHMMSS format to timestamp
      backup_date=${backup_name:0:8}  # YYYYMMDD
      backup_time=${backup_name:9:6}  # HHMMSS

      # Convert to format that date can parse
      formatted_date="${backup_date:0:4}-${backup_date:4:2}-${backup_date:6:2}"
      formatted_date+=" ${backup_time:0:2}:${backup_time:2:2}:${backup_time:4:2}"

      backup_timestamp=$(date -d "$formatted_date" +%s 2>/dev/null)

      # Skip if timestamp conversion failed
      if [[ -z "$backup_timestamp" ]]; then
        error "Failed to parse timestamp for backup ${backup_name@Q}"
        continue
      fi

      # Check if backup is older than cutoff
      if ((backup_timestamp < cutoff_time)); then
        info "Removing old backup: $backup_name (older than $age_days days)"
        rm -rf "$backup" || { error "Failed to remove backup ${backup@Q}"; return 1; }
        pruned_count+=1
      fi
    done < <(find "$backup_dir" -maxdepth 1 -type d -name "$TIMESTAMP_PATTERN")
  fi

  # Report results
  info "Pruning completed: removed $pruned_count backups."
  return 0
}

# =============================================================================
# MAIN ENTRY POINT
# =============================================================================
# Argument parsing and operation dispatch

main() {
  local -- user='' group='' fullbackup_dir='' rel_exclude='' pattern

  # Parse command-line arguments
  while (($#)); do case $1 in
    -d|--backup-dir)
                  noarg "$@"; shift
                  backup_dir=$1
                  ;;
    -s|--suffix)  noarg "$@"; shift 
                  # Sanitize suffix for security
                  suffix=${1//[^[:alnum:]._-]/}
                  [[ -z "$suffix" ]] || suffix=_"$suffix"
                  ;;
    -n|--no-hardlink)
                  hardlink=0 ;;
       --hardlink)
                  [[ -n "$HARDLINK" ]] || die 1 "'hardlink' is not installed."
                  hardlink=1 ;;
    -q|--quiet)   VERBOSE=0 ;;
    -v|--verbose) VERBOSE=1 ;;
    -l|--list)    list_mode=1 ;;
    -r|--restore) restore_mode=1 ;;
    -f|--from)    noarg "$@"; shift
                  restore_source=$1
                  ;;
    -t|--to)      noarg "$@"; shift
                  restore_target=$1
                  ;;
       --dry-run) dry_run=1 ;;
       --diff)    diff_mode=1 ;;
       --compare-with)
                  noarg "$@"; shift
                  compare_source=$1
                  compare_mode=1
                  ;;
       --detailed)
                  compare_detailed=1 ;;
       --files)   noarg "$@"; shift
                  restore_files+=("$1")
                  ;;
    -x|--exclude) noarg "$@"; shift
                  exclude_patterns+=("$1")
                  ;;
       --no-sudo) no_sudo=1 ;;
    -k|--keep)    noarg "$@"; shift
                  if ! [[ "$1" =~ ^[0-9]+$ ]]; then
                    die 22 "Invalid number for --keep option: ${1@Q}"
                  fi
                  keep_count=$1
                  ;;
       --age)     noarg "$@"; shift
                  if ! [[ "$1" =~ ^[0-9]+$ ]]; then
                    die 22 "Invalid number for --age option: ${1@Q}"
                  fi
                  age_days=$1
                  ;;
    -p|--prune-only)
                  prune_only=1 ;;
       --no-lock) use_locking=0 ;;
       --lock-timeout)
                  noarg "$@"; shift
                  if ! [[ "$1" =~ ^[0-9]+$ ]]; then
                    die 22 "Invalid lock timeout value: ${1@Q}"
                  fi
                  lock_timeout=$1
                  ;;
       --force-unlock)
                  force_unlock=1 ;;
    -V|--version) echo "$SCRIPT_NAME $VERSION"; return 0 ;;
    -h|--help)    show_help; return 0 ;;
    # Disaggregate bundled short options; arg-taking opts (-d,-s,-f,-t,-x,-k) must be last
    -[dsnqvrlftxkpVh]?*)  set -- "${1:0:2}" "-${1:2}" "${@:2}"; continue ;;
    -*)           die 22 "Invalid option ${1@Q}" ;;
    *)            [[ -z "$source_dir" ]] || die 1 "Source dir ${source_dir@Q} has already been defined!"
                  source_dir=$1
                  ;;
  esac; shift; done

  # Freeze parsed configuration
  # Note: dry_run, diff_mode, keep_count, age_days are excluded because
  # they are reused as local parameter names in subfunctions
  readonly VERBOSE restore_mode hardlink prune_only no_sudo \
           use_locking lock_timeout force_unlock \
           compare_mode compare_detailed list_mode

  # Verify rsync present
  command -v rsync >/dev/null || die 18 'rsync required: apt install rsync'

  # Calculate timestamp at backup time, not script start time
  local -- datestamp
  datestamp=$(isodate)

  [[ -n "$source_dir" ]] || source_dir="$PWD"
  # Handle path portably using a single canonical path resolution function
  source_dir=$(get_canonical_path "$source_dir")
  [[ -d "$source_dir" ]] || die 1 "No such directory ${source_dir@Q}"

  # Get owner info portably
  read -r user group < <(get_owner_info "$source_dir")

  # Use smart default backup directory based on user privileges
  [[ -n $backup_dir ]] || backup_dir=$(get_default_backup_dir "$source_dir")
  # Handle path portably using the same function
  backup_dir=$(get_canonical_path "$backup_dir")

  # Freeze resolved path configuration
  # Note: source_dir, backup_dir excluded — reused as local names in subfunctions
  # Note: restore_target excluded — modified after canonicalization
  readonly -- suffix restore_source compare_source

  # Handle --no-sudo option by skipping privilege escalation
  if ((no_sudo)); then
    info 'Operating in no-sudo mode, will not attempt privilege escalation'
  fi

  # Check if we can access the backup directory
  if ! check_dir_access "$backup_dir"; then
    # Directory is not accessible with current permissions
    if ((no_sudo)); then
      die 1 "Cannot access backup directory ${backup_dir@Q} and --no-sudo option is set"
    elif ! is_root_or_sudo; then
      die 1 "Cannot access ${backup_dir@Q}." \
           'Use a directory in your home or run with sudo'
    fi
  fi

  # Create backup directory if it doesn't exist
  if [[ ! -d "$backup_dir" ]]; then
    # Only prompt if in VERBOSE mode, otherwise create automatically
    if ((VERBOSE)); then
      error "No such directory ${backup_dir@Q}"

      # Check if we're in a non-interactive environment or if CHECKPOINT_AUTO_CONFIRM is set
      local -- confirm_reply=''
      local -i timeout_secs=30
      if [[ ! -t 0 || -n "${CHECKPOINT_AUTO_CONFIRM:-}" ]]; then
        info 'Auto-creating directory: non-interactive mode' \
             'or CHECKPOINT_AUTO_CONFIRM is set'
        confirm_reply=y
      else
        # Interactive prompt with timeout

        # Inform user about timeout
        printf 'Create backup dir %s? [y/n] ' "${backup_dir@Q}"
        echo "(Automatically answering 'n' in $timeout_secs seconds)"

        # Set up timeout reading
        if ! read -r -t "$timeout_secs" confirm_reply; then
          printf '\nPrompt timed out after %d seconds.\n' "$timeout_secs"
          die 1 'Directory creation cancelled due to timeout'
        fi
      fi

      [[ $confirm_reply == 'y' ]] || die 1 ''
    fi
    mkdir -p "$backup_dir" || die 1 "Could not create directory ${backup_dir@Q}"

    # Only set ownership and sticky bit if we have privileges
    if is_root_or_sudo; then
      chown "$user:$group" "$backup_dir" || error "Failed to set ownership on ${backup_dir@Q}"
      chmod +t "$backup_dir" || error "Failed to set sticky bit on ${backup_dir@Q}"
    else
      info 'Running as non-root: backup directory will retain current user ownership'
    fi
  fi

  # Handle compare mode
  if ((compare_mode)); then
    local -- first_checkpoint
    first_checkpoint=$(_resolve_checkpoint "$backup_dir" "$restore_source" "First checkpoint")

    local -- second_checkpoint
    second_checkpoint=$(_resolve_checkpoint "$backup_dir" "$compare_source" "Second checkpoint")

    # Perform checkpoint comparison
    info 'Comparing checkpoints:'
    info "First:  $(basename -- "$first_checkpoint")"
    info "Second: $(basename -- "$second_checkpoint")"

    compare_checkpoints "$first_checkpoint" "$second_checkpoint" "$compare_detailed" "${restore_files[@]}"
    return 0
  fi

  # Handle restore mode
  if ((restore_mode)); then
    # Set default target directory if not specified
    [[ -n $restore_target ]] || restore_target="$source_dir"
    restore_target=$(get_canonical_path "$restore_target")

    # Perform restore operation
    restore_backup "$backup_dir" "$restore_source" "$restore_target" "$dry_run" "$diff_mode" "${restore_files[@]}"
    return 0
  fi

  # If in list mode, list the checkpoints and exit
  if ((list_mode)); then
    if [[ -d "$backup_dir" ]]; then
      echo "Checkpoints for ${source_dir@Q} in ${backup_dir@Q}:"
      echo "----------------------------------------"

      # Initially empty total size
      local -- total_size=0K
      local -i total_entries=0
      local -i max_length=30  # Default minimum width

      # Build sorted list of checkpoints once (avoid multiple find calls)
      local -a checkpoints=()
      mapfile -t checkpoints < <(find "$backup_dir" -maxdepth 1 -type d -name "$TIMESTAMP_PATTERN" | sort -r)
      total_entries=${#checkpoints[@]}

      # Find the longest name to determine column width
      local -- cp_name checkpoint checkpoint_dir
      local -i len
      for checkpoint in "${checkpoints[@]}"; do
        cp_name=${checkpoint##*/}
        len=${#cp_name}
        if ((len > max_length)); then max_length=$len; fi
      done

      # Add padding
      max_length=$((max_length + 2))

      # Format and display each checkpoint (single du pass)
      local -i total_bytes=0 dir_bytes
      local -- size
      for checkpoint in "${checkpoints[@]}"; do
        dir_bytes=$(du -sk "$checkpoint" | cut -f1)
        total_bytes+=$dir_bytes
        cp_name=${checkpoint##*/}
        # Derive human-readable size from KB value
        if (( dir_bytes >= 1048576 )); then
          size="$((dir_bytes / 1024 / 1024))G"
        elif (( dir_bytes >= 1024 )); then
          size="$((dir_bytes / 1024))M"
        else
          size="${dir_bytes}K"
        fi
        printf "%-${max_length}s %7s\n" "$cp_name" "$size"
      done

      # If no checkpoints found
      if (( total_entries == 0 )); then
        echo 'No checkpoints found.'
      else
        # Convert total to human readable
        if (( total_bytes >= 1048576 )); then
          total_size="$((total_bytes / 1024 / 1024))G"
        elif (( total_bytes >= 1024 )); then
          total_size="$((total_bytes / 1024))M"
        else
          total_size="${total_bytes}K"
        fi

        echo "----------------------------------------"
        echo "Total backups: $total_entries   Total size: $total_size"
      fi
    else
      echo "Backup directory ${backup_dir@Q} does not exist."
    fi
    return 0
  fi

  # Handle prune-only mode - prune backups without creating a new one
  if ((prune_only)); then
    info 'Prune-only mode: pruning backups without creating a new one.'
    prune_backups "$backup_dir" "$keep_count" "$age_days"
    return
  fi

  # Acquire lock for backup directory if locking is enabled
  if ((use_locking)); then
    if ! acquire_lock "$backup_dir"; then
      die 1 "Failed to acquire lock for backup directory ${backup_dir@Q}"
    fi
  fi

  # Check disk space
  if ! check_disk_space "$backup_dir"; then
    die 1 "Insufficient disk space for backup in ${backup_dir@Q}"
  fi

  fullbackup_dir="$backup_dir"/"$datestamp""$suffix"
  
  # Create temporary directory for atomic backup operation
  # Use .tmp prefix to clearly mark as temporary and exclude from listings
  TEMP_BACKUP_DIR=$(mktemp -d "$backup_dir"/.tmp.XXXXXX) || die 1 'Failed to create temp dir'
  
  # Determine the most recent backup for hardlinking (after pruning)
  local -- lastbackup
  if ((hardlink)); then
    lastbackup=$(find "$backup_dir" -maxdepth 1 \
      -type d -name "$TIMESTAMP_PATTERN" | sort | tail -n1)
  fi

  # Show progress based on VERBOSE setting
  info "Creating checkpoint backup ${fullbackup_dir@Q}"

  # Create temporary directory first
  if ! mkdir -p "$TEMP_BACKUP_DIR"; then
    die 1 "Failed to create temporary directory ${TEMP_BACKUP_DIR@Q}"
  fi
  
  # Set ownership on temp directory only if we have privileges
  if is_root_or_sudo; then
    chown "$user:$group" "$TEMP_BACKUP_DIR" \
      || error "Failed to set ownership on ${TEMP_BACKUP_DIR@Q}"
  fi

  # Get relative path from source to backup dir for proper exclusion
  rel_exclude=$(get_relative_path "$source_dir" "$backup_dir")

  # Add progress indicator based on verbosity and terminal
  # Define rsync options as an array - ensure symlinks are preserved
  local -a rsync_opts=(-a -l)
  if ((VERBOSE)) && [[ -t 1 ]]; then
    rsync_opts+=(-h --progress)
  fi

  # Build the rsync command with all exclusion patterns
  local -a exclusions=(
    --exclude="$rel_exclude"/
    --exclude=.gudang/
    --exclude=temp/
    --exclude=.temp/
    --exclude=tmp/
    '--exclude=~*'
    '--exclude=*~'
  )

  # Add user-defined exclusion patterns
  for pattern in "${exclude_patterns[@]}"; do
    exclusions+=("--exclude=$pattern")
  done

  # Execute rsync to temporary directory with error handling
  if ! rsync "${rsync_opts[@]}" "$source_dir"/ "$TEMP_BACKUP_DIR"/ "${exclusions[@]}"; then
    rm -rf "$TEMP_BACKUP_DIR"
    die 1 'Rsync backup failed'
  fi

  # hardlink - perform on temporary directory
  if ((hardlink)) && [[ -n $lastbackup ]]; then
    if [[ -n "$HARDLINK" ]]; then
      info "Hardlinking $lastbackup <-> $TEMP_BACKUP_DIR"
      "$HARDLINK" --respect-name --ignore-mode --ignore-owner --ignore-time --minimum-size 1K --quiet \
          "$lastbackup"/ "$TEMP_BACKUP_DIR"/
    fi
  fi

  # All operations successful - atomically rename temp directory to final name
  if ! mv "$TEMP_BACKUP_DIR" "$fullbackup_dir"; then
    # If rename fails, try to clean up
    rm -rf "$TEMP_BACKUP_DIR"
    die 1 'Failed to finalize backup (atomic rename failed)'
  fi
  
  # Clear TEMP_BACKUP_DIR since it's been successfully renamed
  TEMP_BACKUP_DIR=''

  # Prune old backups if requested
  if ((keep_count > 0 || age_days > 0)); then
    prune_backups "$backup_dir" "$keep_count" "$age_days"
  fi

  # Report backup usage with improved error handling - but only if VERBOSE
  if ((VERBOSE)); then
    local -i numbackups=0
    numbackups=$(find "$backup_dir"/ -maxdepth 1 \
      -type d -name "$TIMESTAMP_PATTERN" | wc -l) || numbackups=0

    # Get disk usage in a portable way
    local -- usage=''
    usage=$(du -sh "$backup_dir"/ 2>/dev/null | awk '{print $1}') || usage="unknown"

    >&2 echo "$numbackups backups in ${backup_dir@Q} ($usage)"
    echo "Backup completed to ${fullbackup_dir@Q}"
  else
    # In quiet mode, just print the backup path
    echo "$fullbackup_dir"
  fi
  
  # Release lock after successful backup
  if ((use_locking)); then
    release_lock "$backup_dir"
  fi
}

main "$@"
#fin
